  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n\n  &-joystick {\n    position: absolute;\n    bottom: 10px;\n    left: 10px;\n\n    border-radius: 50%;\n    border: 1px solid lightgray;\n    width: $size;\n    height: $size;\n\n    &::before {\n      content: \"\";\n      position: absolute;\n      top: 50%;\n      left: 50%;\n      border-radius: 50%;\n      border: 1px solid lightgray;\n      width: $size / 2;\n      height: $size / 2;\n      transform: translate(-50%, -50%);\n    }\n\n    &-handle {\n      $handle-size: $size / 4;\n      position: relative;\n      top: 50%;\n      left: 50%;\n      width: $handle-size;\n      height: $handle-size;\n      transform: translate($size * 3 / 8, 0);\n\n      &-image {\n        position: relative;\n        transform: translate(-50%, -50%);\n        background-color: lightgray;\n        border-radius: 50%;\n        border: 1px solid white;\n        height: $handle-size;\n        width: $handle-size;\n      }\n    }\n  }\n\n  &-actions {\n    position: absolute;\n    bottom: $size / 4;\n    right: $size / 4;\n\n    &-button {\n      user-select: none;\n      border-radius: 50%;\n      border: 1px solid white;\n      width: 100px;\n      height: 100px;\n      font-size: 40px;\n    }\n  }\n}\n\n.menu {\n  text-align: center;\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n\n  background-color: rgba($color: #000000, $alpha: 0.5);\n\n  display: flex;\n  justify-content: center;\n  align-items: center;\n\n  &-panel {\n    display: flex;\n    flex-direction: column;\n\n    border: 1px solid black;\n    padding: 2rem;\n    background-color: white;\n\n    button {\n      margin-bottom: 20px;\n    }\n  }\n}\n\n.game-over {\n  text-align: center;\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  user-select: none;\n  color: white;\n\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  flex-direction: column;\n\n  p {\n    margin-top: 10px;\n   